SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200
ALLOWED_ORIGINS=http://localhost:5173,https://your-vercel-app.vercel.app

# LOCAL: Uses SQLite by default (no DATABASE_URL needed for local dev)
# PRODUCTION: Set DATABASE_URL to your Supabase PostgreSQL connection string
# Example: postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres
# DATABASE_URL=postgresql://postgres.xxxx:YOUR_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
